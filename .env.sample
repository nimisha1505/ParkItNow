# ==============================================================================
# BACKEND SERVER CONFIGURATIONS (server/)
# ==============================================================================

# The port number on which the Node.js Express server will listen.
# Recommended default for API servers: 5000
PORT=5000

# The execution environment configuration. Can be 'development', 'production', or 'test'.
# Set to 'production' when deploying the application live.
NODE_ENV=development

# MongoDB Atlas connection string.
# Replace with your actual Atlas cluster credentials. Do not commit active credentials.
# Format: mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_db_user:your_db_password@your-cluster.mongodb.net/parkitnow?retryWrites=true&w=majority

# Secret key used to sign JSON Web Tokens (JWT) for user authorization.
# Make sure to use a long, complex, random string in production.
JWT_SECRET=your_jwt_signing_secret_key_make_it_long_and_secure

# Token expiration duration. Formats: '7d' (7 days), '24h' (24 hours), '60m' (60 minutes).
JWT_EXPIRE=7d

# Secret API key from your Stripe Dashboard used to authorize server-side charges.
# Keeps payment transactions private and authenticated.
STRIPE_SECRET_KEY=sk_test_replace_with_your_stripe_secret_key

# Webhook signing secret from Stripe CLI or Dashboard.
# Used to verify that events sent to your '/api/v1/payments/webhook' endpoint are genuine Stripe events.
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_stripe_webhook_secret

# Server API token key for Geocoding and Map routing functionalities (e.g., Mapbox or Google Maps Server API key).
MAPS_API_KEY=your_maps_server_side_secret_key

# Allowed client-side URL. Express CORS middleware uses this to whitelist incoming client queries.
# Locally, this matches your React Vite port.
CLIENT_URL=http://localhost:5173


# ==============================================================================
# FRONTEND CLIENT CONFIGURATIONS (client/)
# ==============================================================================

# Public API URL endpoint base for Axios fetches.
# Used by React to connect with the backend API endpoints.
VITE_API_BASE_URL=http://localhost:5000/api/v1

# Public token required to render map interfaces (e.g. Mapbox public token).
# Unlike server keys, this token is public-facing and safe to expose in client code.
VITE_MAPS_PUBLIC_TOKEN=pk.your_public_maps_token_value

# Publishable key from your Stripe Dashboard.
# Used by Stripe Elements inside the React UI to mount billing and card input components securely.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_with_your_stripe_publishable_key
