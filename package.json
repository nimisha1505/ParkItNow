{
  "name": "parkitnow",
  "version": "1.0.0",
  "description": "Smart Parking Reservation Platform - Root Repository",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "client": "npm run dev --workspace=client",
    "server": "npm run dev --workspace=server",
    "dev": "concurrently --kill-others-on-fail \"npm run server\" \"npm run client\"",
    "lint": "npm run lint --workspaces",
    "format": "prettier --write \"**/*.{js,jsx,json,css,md}\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "mern",
    "parking",
    "reservation",
    "react",
    "express",
    "mongodb",
    "nodejs"
  ],
  "author": "",
  "license": "MIT"
}
